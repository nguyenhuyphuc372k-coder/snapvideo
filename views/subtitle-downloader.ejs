<%- include('partials/head') %>
<%- include('partials/header') %>

<div class="container-sm">
  <div class="page-header">
    <h1><%= t.subtitlePageTitle %></h1>
    <p><%= t.subtitlePageDesc %></p>
  </div>

  <div class="input-wrap">
    <div class="input-group">
      <input type="url" id="urlInput" placeholder="https://www.youtube.com/watch?v=..." autocomplete="off" />
      <button class="btn" id="fetchBtn" onclick="fetchSubtitles()"><%= t.btnGetSubtitles %></button>
    </div>
    <div class="status" id="status"></div>
  </div>

  <div id="subtitlesList" style="margin-top:20px;display:none"></div>
</div>

<div class="section section-alt">
  <div class="container">
    <h2><%= t.howToDownloadSubs %></h2>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h3><%= t.pasteURL %></h3>
        <p><%= t.subStep1Desc %></p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3><%= t.fetchSubtitles %></h3>
        <p><%= t.subStep2Desc.replace('{btn}', t.btnGetSubtitles) %></p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3><%= t.btnDownload %></h3>
        <p><%= t.subStep3Desc.replace('{btn}', t.downloadSrt) %></p>
      </div>
    </div>
  </div>
</div>

<div class="section">
  <div class="container-sm">
    <h2><%= t.faqTitle %></h2>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-q"><%= t.subFaq1Q %></button>
        <div class="faq-a"><%= t.subFaq1A %></div>
      </div>
      <div class="faq-item">
        <button class="faq-q"><%= t.subFaq2Q %></button>
        <div class="faq-a"><%= t.subFaq2A %></div>
      </div>
    </div>
  </div>

<div class="section">
  <div class="container">
    <h2 style="text-align:center"><%= t.relatedTools %></h2>
    <div class="tools-grid" style="margin-top:16px">
      <a class="tool-card" href="<%= langPrefix %>/youtube-downloader"><h3><%= t.youtubeTitle %></h3><p><%= t.youtubeDesc %></p></a>
      <a class="tool-card" href="<%= langPrefix %>/youtube-thumbnail-downloader"><h3><%= t.thumbnailTitle %></h3><p><%= t.thumbnailDesc %></p></a>
      <a class="tool-card" href="<%= langPrefix %>/mp4-to-mp3"><h3><%= t.mp4ToMp3Title %></h3><p><%= t.mp4ToMp3Desc %></p></a>
    </div>
  </div>
<%- include('partials/footer') %>
