          <a href="<%= langPrefix %>/youtube-downloader">YouTube</a>
          <a href="<%= langPrefix %>/instagram-downloader">Instagram</a>
          <a href="<%= langPrefix %>/facebook-video-downloader">Facebook</a>
          <a href="<%= langPrefix %>/twitter-video-downloader">Twitter/X</a>
          <a href="<%= langPrefix %>/xiaohongshu-video-downloader">Xiaohongshu</a>
          <a href="<%= langPrefix %>/douyin-video-downloader">Douyin</a>
          <a href="<%= langPrefix %>/bilibili-video-downloader">Bilibili</a>
        </div>
